for (i in seq_along(es_names_SA)) {
# 1. Mapeia o serviço no espaço ambiental
res_map_SA <- lets.maplizer.env(
res_SA,
y = ES_SA[[es_names_SA[i]]],
z = ES_SA$species,
func = sum
)
out_SA_cells <- lets.envcells(res_SA)
abund_env_SA <- res_map_SA$Matrix_env[, -(1:3), drop = FALSE]
# 2. Monta a tabela de dados para o gráfico e modelo
data_plot_SA[[i]] <- tibble(
es_SA = es_names_SA[i],
Abundance_SA = abund_env_SA[, 1],
out_SA_cells[keep_SA, -1],
.name_repair = "unique"
) %>%
drop_na() %>%
select(es_SA, Abundance_SA, Frequency, `Isolation (Mean)`, `Frequency Weighted Distance`) %>%
pivot_longer(cols = 3:5)
# 3. Roda o Modelo Estatístico (GAM)
gam_results_SA[[i]] <- data_plot_SA[[i]] %>%
group_by(name) %>%
summarise(
modelo = list(mgcv::gam(Abundance_SA ~ s(value), data = pick(everything())))
)
# 4. PARTE NOVA: GERANDO OS RESÍDUOS EM PDF
# Isso vai criar um arquivo PDF na sua pasta para cada serviço
pdf(paste0("Residuos_", es_names_SA[i], ".pdf"), width = 8, height = 8)
# Layout para caber os 4 gráficos do gam.check na mesma página
par(mfrow = c(2, 2))
for(j in 1:nrow(gam_results_SA[[i]])) {
mod_temp <- gam_results_SA[[i]]$modelo[[j]]
var_nome <- gam_results_SA[[i]]$name[j]
# Roda o diagnóstico (ele vai desenhar direto no PDF)
mgcv::gam.check(mod_temp)
# Adiciona um título no topo para você saber qual variável está olhando
mtext(paste("Serviço:", es_names_SA[i], "\nVariável:", var_nome),
side = 3, line = -2, outer = TRUE, font = 2, cex = 0.8)
}
dev.off() # Fecha o PDF e salva o arquivo
}
