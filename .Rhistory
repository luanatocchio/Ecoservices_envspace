traits_species_total <- read.csv("Data//Traits_final.csv")
# Ordering species names
# 1. Obtaining species order in community_PAM matrix
ordem_especies_total <- colnames(community_PAM_clean_total)
# 2. Reordering species name in the traits´ dataframe according to species name in community_PAM matrix
traits_species_total <- traits_species_total[match(ordem_especies_total, traits_species_total$iucn2020_binomial), ]
# Changing values in "activity_cycle" column (categorical)
traits_species2_total <- traits_species_total
traits_species2_total$activity_cycle <- ifelse(traits_species2_total$activity_cycle == 1, "nocturnal only",
ifelse(traits_species2_total$activity_cycle == 2, "mixed",
ifelse(traits_species2_total$activity_cycle == 3, "diurnal only", NA)))
# Testing
traits_species2_total$iucn2020_binomial == colnames(community_PAM_clean_total)
traits_species2_total
save(traits_species2_total, file = "Data\\FD_table.RData")
write.csv(traits_species2_total, "FD_table_csv.csv", row.names = FALSE)
