# Linhas de depuração
print(paste("Processando:", es_names[i]))
print(paste("Dimensões de abund_env:", paste(dim(abund_env), collapse = " x ")))
print(paste("Comprimento de keep:", length(keep)))
print(paste("Primeiros valores de keep:", head(keep)))
