}
abund_env <- res_map$Matrix_env[, -(1:3), drop = FALSE]
if(ncol(abund_env) > 0) {
Abundance = abund_env[keep, 1]
} else {
warning(paste("abund_env não tem colunas para", es_names[i]))
next  # Pula para a próxima iteração
}
# Diagnóstico
cat("=== DIAGNÓSTICO ===\n")
cat("Dimensões de res$Presence_and_Absence_Matrix_env:\n")
print(dim(res$Presence_and_Absence_Matrix_env))
cat("\nComprimento de keep:", length(keep))
cat("\nPrimeiros 10 valores de keep:\n")
print(head(keep, 10))
cat("Soma de TRUE em keep:", sum(keep, na.rm = TRUE))
# Agora dentro do loop, antes do erro
for (i in seq_along(es_names)) {
cat("\n\n=== Processando:", es_names[i], "===\n")
res_map <- lets.maplizer.env(
res,
y = ES[[es_names[i]]],
z = ES$species,
func = sum
)
cat("Dimensões de res_map$Matrix_env:\n")
print(dim(res_map$Matrix_env))
abund_env <- res_map$Matrix_env[, -(1:3), drop = FALSE]
cat("Dimensões de abund_env:\n")
print(dim(abund_env))
cat("Número de linhas em abund_env:", nrow(abund_env), "\n")
cat("Comprimento de keep:", length(keep), "\n")
# Verificar se as dimensões correspondem
if(nrow(abund_env) != length(keep)) {
cat("⚠️ ALERTA: Dimensões NÃO correspondem!\n")
cat("Diferença:", abs(nrow(abund_env) - length(keep)), "linhas\n")
}
# Tentar acessar com keep e verificar o erro específico
if(sum(keep) > 0) {
max_keep_index <- max(which(keep))
cat("Maior índice TRUE em keep:", max_keep_index, "\n")
cat("Número total de linhas em abund_env:", nrow(abund_env), "\n")
if(max_keep_index > nrow(abund_env)) {
cat("❌ ERRO: O índice", max_keep_index, "excede o número de linhas (",
nrow(abund_env), ")\n")
}
}
# Interrompa após o primeiro para análise (opcional)
if(i == 1) {
cat("\nPressione Enter para continuar ou interrompa para ajustar...")
readline()
}
}
