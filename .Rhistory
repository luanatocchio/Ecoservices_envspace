# Loading South America Polygon
SA <- st_read("Data\\Primary Data\\SA\\Lim_america_do_sul_2021.shp")
SA <- st_transform(SA, crs(clim))
#terra::ext(SA)
clim_SA0 <- terra::crop(clim, SA)
clim_SA <- terra::mask(clim_SA0, SA)
### Log, because effects of precipitation tend to be log scale
v <- values(clim_SA)[, 2]
logv <- sqrt(v)
values(clim_SA)[, 2] <-  ifelse(is.infinite(logv), NA, logv)
mammals <- st_read("Data\\Primary Data\\mammals_polygons\\data_0.shp")
mammals <- mammals %>%
rename(SCINAME = SCI_NAME)
pam_mammals_SA <- lets.load(file = "Data\\Secondary Data\\pam_SA.RData")
plot(pam_mammals_SA)
vale_species <- read.csv("Data/Primary Data/vale_species_last.csv")[[1]]
pam_mammals_sub_SA <- lets.subsetPAM(x = pam_mammals_SA, names = vale_species, remove.cells = FALSE)
plot(pam_mammals_sub_SA, xlab = "Longitude", ylab = "Latitude",
main = "Mammals species richness")
differences_vale_pam_mammals_sub_SA <- setdiff(vale_species, pam_mammals_sub_SA$Species_name)
differences_pam_mammals_sub_SA_vale <- setdiff(pam_mammals_sub_SA$Species_name, vale_species)
ES_SA <- read.csv("Data/Primary Data/ES_11_TraitsNOVO.csv")
ES_SA$total <- rowSums(ES_SA[, -1])
# Environment PAM ---------------------------------------------------------
# Add variables to pam
envs_SA <- lets.addvar(pam_mammals_sub_SA, clim_SA, onlyvar = TRUE)
colnames(envs_SA) <- c("Temperature", "Precipitation (Log)")
# Create Env pam
res_SA <- lets.envpam(pam_mammals_sub_SA, envs_SA,   n_bins = 30)
lets.plot.envpam(res_SA,
world = TRUE)
es_names_SA <- names(ES_SA)[-1]
data_plot_SA <- list()
gam_results_SA <- list()
# Mantain cells without zero
keep_SA <- res_SA$Presence_and_Absence_Matrix_env[, 1]
for (i in seq_along(es_names_SA)) {
res_map_SA <- lets.maplizer.env(
res_SA,
y = ES_SA[[es_names_SA[i]]],
# Change for each ecosystem service
z = ES_SA$species,
func = sum
) # Change here for mean, sum, variability
out_SA <- lets.envcells(res_SA)
# lets.plot.envpam(res_map) # for ploting (if you want to save it)
abund_env_SA   <- res_map_SA$Matrix_env[, -(1:3), drop = FALSE]
data_plot_SA[[i]] <-
tibble(es_SA = es_names_SA[i], Abundance_SA = abund_env_SA[, 1], out_SA[keep_SA, -1]) %>%
drop_na() %>%
# mutate(Frequency_log = log(Frequency)) %>%
select(c(1:3, 7, 15)) %>% # Select variables
pivot_longer(3:5)
# ... (código anterior)
data_plot_SA[[i]] <- tibble(
es_SA = es_names_SA[i],
Abundance_SA = abund_env_SA[, 1],
out_SA[keep_SA, -1],
.name_repair = "unique"
) %>%
drop_na() %>%
select(es_SA, Abundance_SA, Frequency, `Isolation (Mean)`, `Frequency Weighted Distance`) %>%
pivot_longer(cols = 3:5)
# ---------------------------------------------------------
# STATISTICAL MODEL (A Peça que Faltava)
# O dplyr agrupa pelas 3 variáveis espaciais e roda um GAM para cada
# ---------------------------------------------------------
gam_results_SA[[i]] <- data_plot_SA[[i]] %>%
group_by(name) %>%
summarise(
# Roda o modelo usando 'value' (que representa as 3 variáveis alternadamente)
modelo = list(mgcv::gam(Abundance_SA ~ s(value), data = pick(everything())))
)
# STATISTICAL MODEL
# gam_results[[i]] <- gam(Abundance ~ ) Dplyr roda modelo para as 3 variaveis e guardar numa (salvar numa lista)
}
out_SA <- do.call(bind_rows, data_plot_SA)
# Plot
out_SA %>%
ggplot(aes(y = Abundance_SA, x = value)) +
geom_smooth(method = "gam") +
#stat_smooth(method = "lm", formula = y ~ x + I(x^2), size = 1) +
geom_point() +
theme_bw() +
facet_grid(es_SA~name, scales = "free")
library(broom)
library(tidyr)
library(purrr)
library(dplyr)
resultados_r2_servico1 <- gam_results_SA[[1]] %>%
mutate(metricas = map(modelo, broom::glance)) %>%
unnest(metricas) %>%
select(-modelo) # Remove a coluna com os modelos brutos para limpar a tela
# Visualize no seu console:
print(resultados_r2_servico1)
# Extraindo P-valores do Serviço 1
resultados_pvalor_servico1 <- gam_results_SA[[1]] %>%
mutate(coeficientes = map(modelo, broom::tidy)) %>%
unnest(coeficientes) %>%
select(-modelo)
# Visualize no seu console:
print(resultados_pvalor_servico1)
# 1. Dá os nomes dos serviços para as gavetas da lista (para sabermos quem é quem)
names(gam_results_SA) <- es_names_SA
# 2. Une todas as gavetas em uma tabela gigante
todos_os_modelos <- bind_rows(gam_results_SA, .id = "Servico_Ecossistemico")
# 3. Extrai TUDO de uma vez (P-valores e R-quadrado combinados)
tabela_final_tese <- todos_os_modelos %>%
# Puxa o p-valor da curva
mutate(coeficientes = map(modelo, broom::tidy)) %>%
# Puxa o R2 e Deviance
mutate(qualidade = map(modelo, broom::glance)) %>%
# Abre as bonecas russas
unnest(c(coeficientes, qualidade), names_sep = "_") %>%
# Limpa colunas desnecessárias para não poluir
select(
Servico_Ecossistemico,
Variavel_Espacial = name,
Graus_Liberdade = coeficientes_edf,
Estatistica_F = coeficientes_statistic,
P_valor = coeficientes_p.value,
R_Quadrado_Ajustado = qualidade_adj.r.squared,
Deviance_Explicada = qualidade_deviance
)
# 4. Salva o resultado final no seu HD para abrir no Excel ou anexar na tese
write.csv(tabela_final_tese, "Data/Secondary Data/Resultados_Estatisticos_GAM.csv", row.names = FALSE)
library(ggplot2)
out_SA_final %>%
# Adicionamos 'color = es_SA' para dar uma cor distinta a cada serviço
ggplot(aes(y = Abundance_SA, x = value, color = es_SA)) +
# 1. Ajuste dos pontos: alpha = 0.3 deixa eles transparentes.
# Isso permite ver onde os dados estão realmente concentrados.
geom_point(alpha = 0.3, size = 1.2) +
# 2. Ajuste da Curva GAM: Colocamos preta e mais grossa para destacar do fundo colorido
geom_smooth(method = "gam", color = "black", linewidth = 1, se = TRUE) +
# 3. O Grid: O 'scales = "free"' é vital porque o Isolation e a Frequency têm números muito diferentes
facet_grid(es_SA ~ name, scales = "free") +
# 4. Nomes de Eixos Acadêmicos
labs(
y = "Provisão do Serviço Ecossistêmico (Soma)",
x = "Valor da Variável Espacial",
# Você pode tirar o título se for colocar legenda no Word depois
title = "Efeito da Estrutura Espacial sobre Serviços Ecossistêmicos"
) +
# 5. Estética Minimalista e Limpa (Foco na informação)
theme_bw(base_size = 14) + # base_size = 14 deixa a fonte com tamanho ideal para leitura no papel
theme(
legend.position = "none", # Esconde a legenda, pois o facet já diz qual é o serviço
strip.background = element_rect(fill = "white", color = "black"), # Fundo do título branco e clean
strip.text = element_text(face = "bold", size = 12), # Títulos das caixinhas em negrito
panel.grid.minor = element_blank() # Remove as linhas de grade menores para não poluir
)
out_SA_final %>%
# Adicionamos 'color = es_SA' para dar uma cor distinta a cada serviço
